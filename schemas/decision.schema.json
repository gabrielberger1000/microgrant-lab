{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://microgrant-lab.local/schemas/decision.schema.json",
  "title": "Microgrant Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "case_id",
    "created_at",
    "reviewer_type",
    "decision",
    "grant_amount_usd",
    "confidence",
    "rationale",
    "policy_checks",
    "flags",
    "requested_followup"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "case_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer_type": {
      "type": "string",
      "enum": ["baseline_policy", "ai_assist", "human", "appeal_review"]
    },
    "model": {
      "type": ["string", "null"]
    },
    "decision": {
      "type": "string",
      "enum": ["approve", "deny", "needs_more_info", "needs_review"]
    },
    "grant_amount_usd": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 300
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "string"
    },
    "policy_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "details"],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "unknown", "review"]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_followup": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
